# Copy to .env.local and fill in real values. .env.local is gitignored.
# On Vercel/hosting these must ALL be added as project Environment Variables —
# .env.local is NOT deployed. DATABASE_URL + AUTH_SECRET are required for the
# app to work at all (login/session); the rest power the /api/chat agent.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:26257/defaultdb?sslmode=verify-full

# Secret that signs session cookies. REQUIRED — login/session 500s without it.
# Generate one: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
AUTH_SECRET=

# CockroachDB Cloud managed MCP Server (used by the /api/chat agent).
# URL + cluster id come from the cluster's Connect > MCP snippet; the API key
# belongs to a service account with Cluster Admin scoped to the cluster.
CRDB_MCP_URL=https://cockroachlabs.cloud/mcp
CRDB_MCP_API_KEY=
CRDB_MCP_CLUSTER_ID=

# Bedrock (agent reasoning). Uses your local AWS credentials (aws configure);
# no keys go in this file.
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
