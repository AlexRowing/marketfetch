# Copy to .env and fill in real values. .env is gitignored — NEVER commit it
# (and never `git add -f` it; the root .gitignore blocks it for a reason).

# CockroachDB Cloud — from the console's Connect dialog ("General connection string").
DATABASE_URL=postgresql://USER:PASSWORD@HOST:26257/defaultdb?sslmode=verify-full

# AWS / Bedrock (used by the agent worker)
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
